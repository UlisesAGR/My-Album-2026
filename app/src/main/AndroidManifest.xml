<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="true" />

    <application
        android:name=".base.App"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/APP_NAME"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyAlbum2026"
        tools:ignore="DataExtractionRules">

        <activity
            android:name=".presenter.ui.dashboard.cards.view.CardsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MyAlbum2026"
            android:windowSoftInputMode="stateHidden|adjustPan" />
        <activity
            android:name=".presenter.ui.dashboard.countries.view.CountryListActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MyAlbum2026"
            android:windowSoftInputMode="stateHidden|adjustPan" />
        <activity
            android:name=".presenter.ui.dashboard.missing.view.CardsMissingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MyAlbum2026"
            android:windowSoftInputMode="stateHidden|adjustPan" />
        <activity
            android:name=".presenter.ui.dashboard.obtained.view.CardsObtainedActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MyAlbum2026"
            android:windowSoftInputMode="stateHidden|adjustPan" />
        <activity
            android:name=".presenter.ui.dashboard.container.view.DashboardActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MyAlbum2026"
            android:windowSoftInputMode="stateHidden|adjustPan" />
        <activity
            android:name=".presenter.ui.welcome.view.WelcomeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MyAlbum2026"
            android:windowSoftInputMode="stateHidden|adjustPan" />
        <activity
            android:name=".presenter.ui.splash.view.SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Splash.Theme.Starting"
            android:windowSoftInputMode="stateHidden|adjustPan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="@string/ad_app_id" />
    </application>

</manifest>