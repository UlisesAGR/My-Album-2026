<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/padding_16"
    android:paddingTop="@dimen/padding_32"
    android:paddingBottom="@dimen/padding_16">

    <ImageView
        android:id="@+id/logoImageView"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="@null"
        android:src="@drawable/il_flag_europe" />

    <TextView
        android:id="@+id/teamNameTextView"
        style="@style/text_extra.bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_12"
        android:textSize="18sp"
        tools:text="Argentina" />

    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginHorizontal="@dimen/margin_16"
        android:layout_weight="1"
        android:background="@color/divider_color" />

    <TextView
        android:id="@+id/teamCountTextView"
        style="@style/text_medium.bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="10 / 20 Missing" />

</LinearLayout>
