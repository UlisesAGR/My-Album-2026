<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/itemRoot"
    style="@style/selectableStyle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/margin_8"
    android:layout_marginVertical="@dimen/margin_8"
    android:backgroundTint="@color/special_background"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/divider_color"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="@dimen/padding_16">

        <TextView
            android:id="@+id/cardPosition"
            style="@style/text_medium.bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/black_color"
            tools:text="POR" />

        <TextView
            android:id="@+id/idNumber"
            style="@style/text_medium.bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_12"
            android:background="@drawable/bg_circle"
            android:gravity="center"
            android:paddingHorizontal="@dimen/margin_12"
            android:paddingTop="@dimen/margin_16"
            android:paddingBottom="@dimen/margin_10"
            android:textColor="@color/black_color"
            tools:text="FWC-01" />

        <TextView
            android:id="@+id/cardQuantity"
            style="@style/text_medium.bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_24"
            android:background="@drawable/bg_square"
            android:gravity="center"
            android:paddingTop="@dimen/margin_10"
            android:paddingBottom="@dimen/margin_6"
            android:textColor="@color/black_color"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="100" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
